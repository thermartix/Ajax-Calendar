#!/bin/sh

GITLEAKS_BIN="gitleaks"
if ! command -v "$GITLEAKS_BIN" >/dev/null 2>&1; then
  WIN_GITLEAKS="/c/Users/marti/AppData/Local/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe"
  if [ -x "$WIN_GITLEAKS" ]; then
    GITLEAKS_BIN="$WIN_GITLEAKS"
  else
    echo "gitleaks not found. Install it first: winget install --id Gitleaks.Gitleaks -e"
    exit 1
  fi
fi

echo "Running gitleaks on staged changes..."
"$GITLEAKS_BIN" protect --staged --redact --verbose --config .gitleaks.toml
status=$?
if [ "$status" -ne 0 ]; then
  echo "Commit blocked: potential secret detected."
  exit "$status"
fi

exit 0
